; StackTabs configuration

[General]
; WindowTitleMatch is a single pattern (legacy). Use Match1/Match2/... for multiple patterns.
WindowTitleMatch=Power
; Match1=Ticket details
; Match2=Customer portal
TargetExe=
RefreshInterval=200
CaptureDelayMs=900
TabDisappearGraceMs=300

[Layout]
HostTitle=StackTabs
HostWidth=1200
HostHeight=800
HostMinWidth=700
HostMinHeight=500
HostPadding=8
HeaderHeight=44
TabGap=6
MinTabWidth=120
MaxTabWidth=240
TabHeight=30
TabSlotMax=50
TabTitleMaxLen=60
CloseButtonWidth=22
PopoutButtonWidth=22
TabBarOffsetY=7
TabPosition=top
UseCustomTitleBar=0
TitleBarHeight=28

[Theme]
; Theme file to load from the themes\ folder. Defaults to dark.ini if not set.
ThemeFile=dark.ini

[TitleFilters]
; Each StripN entry is a regex pattern removed from window titles before display.
; Patterns are applied in order; result is trimmed of surrounding whitespace.
; Strip1=^App - \s*
; Strip2=\s*- MyApp$

[Session]
; Window position and size are saved here automatically on exit.
; Delete these lines to reset to default placement.
; WindowX=100
; WindowY=100
; WindowW=1200
; WindowH=800
