; ============================================
; StackTabs Configuration Example
; ============================================
; Copy this file to config.ini and edit as needed.
; Restart StackTabs after saving changes.

[General]
; --- Window matching ---
; Match1/Match2/... = window title substrings. A window must contain at least one to be captured.
; Special: Match=""  captures windows with an empty or whitespace-only title.
;          Always combine with TargetExe= when using "" to avoid grabbing every untitled window.
Match1=PowerShell
; Match2=Notepad
; Match3=Visual Studio Code
; Match4=""          ; captures untitled windows (pair with TargetExe)

; Optional: limit to a specific process (e.g. pwsh.exe). Leave empty to match any process.
TargetExe=

; --- Timing (all in milliseconds) ---
SlowSweepInterval=3000      ; Fallback scan interval. Catches windows the Shell Hook might miss.
StackDelayMs=100            ; Minimum wait before stacking (title must also be stable).
StackSwitchDelayMs=150      ; Delay before switching to a newly stacked tab.
WatchdogMaxMs=1500          ; Max wait for hung windows before giving up.
TabDisappearGraceMs=300     ; Grace period before removing a tab whose window closed.

; DebugDiscovery=0          ; Set to 1 to log window discovery events (Win+Shift+D to dump).
; BumpOnChildDialog=0       ; Set to 1 to bring StackTabs forward when an embedded app opens a dialog.

[Layout]
; --- Host window ---
HostTitle=StackTabs
HostWidth=1200
HostHeight=800
HostMinWidth=700
HostMinHeight=500
HostPadding=8               ; Padding around the tab bar (left/right/top).

; --- Tab bar ---
HeaderHeight=36             ; Height of the tab bar in pixels.
TabHeight=30                ; Height of each tab button.
TabBarAlignment=center      ; Vertical alignment of tabs within the bar: top, center, bottom.
TabGap=6                    ; Gap between tabs in pixels.
MinTabWidth=120
MaxTabWidth=240

; --- Tab titles ---
; TabTitleMaxLen=60         ; Optional. Omit for fully dynamic (fits tab width). Set to cap titles shorter.
TabMaxLines=1               ; 1 = single line with ellipsis; 2+ = word-wrap across multiple lines.
TabTitleAlignH=center       ; Horizontal text alignment: left, center, right.
TabTitleAlignV=center       ; Vertical text alignment: top, center. Ignored when TabMaxLines>=2 (always top).
ShowTabNumbers=0            ; 1 = prefix titles with position: "1. Title", "2. Title", etc.

; --- Tab buttons ---
CloseButtonWidth=22
PopoutButtonWidth=22

; --- Tab style ---
TabPosition=top             ; Position of the tab bar: top or bottom.
TabIndicatorHeight=3        ; Height of the active-tab indicator strip (px). 0 to disable.
ActiveTabStyle=full         ; full = active tab has a distinct background; indicator = accent strip only.

; --- Behavior ---
ShowOnlyWhenTabs=1          ; 1 = hide to tray when no tabs; show when 1+ tabs (default). 0 = always show.
UseCustomTitleBar=0         ; 1 = custom title bar that matches the theme. 0 = system title bar.
TitleBarHeight=28           ; Height of the custom title bar (only relevant when UseCustomTitleBar=1).

[Theme]
; Theme file from the themes\ folder.
; Available: dark.ini, light.ini, spacious.ini, spacious-dark.ini, compact.ini,
;            bottom-tabs.ini, high-contrast.ini, minimal.ini, numbered.ini, tmux.ini
ThemeFile=dark.ini

[TitleFilters]
; Strip1/Strip2/... = regex patterns removed from window titles before display.
; Applied in order; result is trimmed. Useful to shorten long window titles.
; Strip1=^MyApp - \s*
; Strip2=\s*- Microsoft Edge$
